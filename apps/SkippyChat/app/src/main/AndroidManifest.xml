<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-feature android:name="android.hardware.microphone" android:required="false" />
    <uses-feature android:name="android.hardware.sensor.proximity" android:required="false" />

    <!-- SMS send + receive -->
    <uses-permission android:name="android.permission.SEND_SMS" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_SMS" />
    <!-- Contact name → phone number resolution -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <!-- DropShip auto-upload — watch MediaStore for new photos -->
    <!-- API 33+ (Android 13+): granular media permission -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <!-- API 30-32 fallback (ignored on 33+) -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!-- Required to show foreground-service notification -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Android 14+: must declare the service type -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- Start DropShipWatcher on boot / after package update -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Show upload notification on Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
      Package visibility (Android 11+). SkippyChat resolves launch intents
      for sibling Skippy apps and Chrome when the Captain rotates between
      slots — see the rotation-handoff block in MainActivity.kt.
        - local.skippy.droid: landscape HUD slot (USB on right)
        - com.android.chrome: other landscape slot (USB on left); falls
          back to ACTION_VIEW http if Chrome is absent.
        - ACTION_MAIN/CATEGORY_HOME doesn't need <queries>.
      Without these declarations getLaunchIntentForPackage / queryIntent
      return null even when the targets are installed.
    -->
    <queries>
        <package android:name="local.skippy.droid" />
        <package android:name="com.android.chrome" />
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="http" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
    </queries>

    <application
        android:allowBackup="false"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@drawable/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.SkippyChat"
        tools:targetApi="31">

        <!--
          Orientation is `sensor` rather than `portrait` so rotating the
          phone to landscape is caught by `onConfigurationChanged` and used
          as the signal to hand off to SkippyDroid (glasses mirror).

          `launchMode=singleTask` so SkippyDroid's reverse handoff brings
          the existing SkippyChat task back to front — scrollback stays
          intact across rotations rather than being rebuilt from nothing.
        -->
        <!--
          SkippyChat is the device's primary home surface.

          The HOME + DEFAULT intent filter makes it available as a launcher
          choice. Set it as default once (or via ADB below) and the phone
          wakes directly into SkippyChat — no Android desktop flash.

          Rotation slots:
            ROTATION_0   (upright portrait)       → SkippyChat stays
            ROTATION_90  (USB on right / glasses) → SkippyDroid HUD
            ROTATION_180 (upside-down)            → Android backup launcher
            ROTATION_270 (USB on left)            → Services panel

          android:screenOrientation="sensor" is required so that physical
          rotation events reach onConfigurationChanged for slot handoff.
          The activity itself sets requestedOrientation = PORTRAIT on every
          onResume so SkippyChat is always the anchored home surface.

          adb one-liner to set SkippyChat as default home:
            adb shell cmd package set-home-activity local.skippy.chat/.MainActivity
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="sensor"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:windowSoftInputMode="stateAlwaysHidden|adjustResize">
            <!-- Standard app launcher icon -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Home launcher — replaces Android desktop on wake/home button -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!--
          SkippyDeviceAdmin — grants force-lock so PocketDetector can call
          DevicePolicyManager.lockNow() when the proximity sensor detects
          the phone has been pocketed.

          One-time activation after install:
            adb shell dpm set-active-admin local.skippy.chat/.admin.SkippyDeviceAdmin
        -->
        <receiver
            android:name=".admin.SkippyDeviceAdmin"
            android:exported="true"
            android:permission="android.permission.BIND_DEVICE_ADMIN">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/skippy_device_admin" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>

        <!--
          SmsReceiver — receives incoming SMS and posts to the in-process
          SharedFlow that ChatScreen collects. Priority 999 so we see the
          message before lower-priority receivers (e.g. the default SMS app).
          exported=false: no other app needs to send this intent to us.
        -->
        <receiver
            android:name=".sms.SmsReceiver"
            android:exported="false"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter android:priority="999">
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>

        <!--
          DropShipWatcher — foreground service that watches MediaStore for new
          photos and uploads them to SkippyTel /dropship/upload. Keeps running
          in the background so photos taken while SkippyChat is closed are
          still uploaded. foregroundServiceType="dataSync" required for API 34+.
        -->
        <service
            android:name=".dropship.DropShipWatcher"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!--
          DropShipBootReceiver — starts DropShipWatcher after boot and after
          the app is updated. RECEIVE_BOOT_COMPLETED declared above.
        -->
        <receiver
            android:name=".dropship.DropShipBootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
